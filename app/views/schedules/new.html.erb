<% content_for(:title, t('.title')) %>
<div class="max-w-md mx-auto mt-10 px-6">
  <h1 class="text-2xl font-bold mb-6 text-center"><%= t('.title') %></h1>
  <%= form_with model: @schedule do |f| %>
    <%= render "shared/error_messages", object: f.object %>
    <div class="mb-4">
      <%= f.label :title, class: "block text-lg font-medium text-gray-700 mb-1" %>
      <%= f.text_field :title, class: "w-full border border-gray-300 rounded px-4 py-3 text-lg" %>
    </div>
    <div class="mb-4">
      <%= f.label :start_time, class: "block text-lg font-medium text-gray-700 mb-1" %>
      <%= f.datetime_field :start_time, class: "w-full border border-gray-300 rounded px-4 py-3 text-lg" %>
    </div>
    <div class="mb-4">
      <%= f.label :end_time, class: "block text-lg font-medium text-gray-700 mb-1" %>
      <%= f.datetime_field :end_time, class: "w-full border border-gray-300 rounded px-4 py-3 text-lg" %>
    </div>
    <div class="mb-4">
      <%= f.label :location, class: "block text-lg font-medium text-gray-700 mb-1" %>
      <%= f.text_field :location, class: "w-full border border-gray-300 rounded px-4 py-3 text-lg" %>
    </div>
    <div class="mb-6">
      <%= f.label :description, class: "block text-lg font-medium text-gray-700 mb-1" %>
      <%= f.text_area :description, rows: 4, class: "w-full border border-gray-300 rounded px-4 py-3 text-lg" %>
    </div>
    <%= f.submit class: "w-full bg-gray-800 text-white text-xl font-bold py-4 rounded hover:bg-gray-700 transition cursor-pointer" %>
  <% end %>
</div>
