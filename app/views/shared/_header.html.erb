<%# 共通ヘッダー：ロゴ + ログイン状態に応じたナビゲーション %>
<header class="flex items-center justify-between px-8 py-4 bg-gray-800">
  <%= link_to "RoboCup Supporter", root_path, class: "text-white text-2xl font-bold" %>
  <nav class="flex gap-3">
    <% if logged_in? %>
      <span class="text-white px-3 py-2"><%= current_user.name %></span>
      <%= link_to "ログアウト", logout_path, data: { turbo_method: :delete }, class: "border border-white text-white px-5 py-2 rounded hover:bg-white hover:text-gray-800 transition" %>
    <% else %>
      <%= link_to "新規登録", new_user_path, class: "border border-white text-white px-5 py-2 rounded hover:bg-white hover:text-gray-800 transition" %>
      <%= link_to "ログイン", login_path, class: "bg-white text-gray-800 px-5 py-2 rounded hover:bg-gray-100 transition" %>
    <% end %>
  </nav>
</header>
