<main class="max-w-4xl mx-auto px-4 py-8">
  <h1 class="text-3xl font-bold mb-6">教室カレンダー</h1>

  <div class="bg-white rounded-lg shadow p-4 mb-8 text-lg">
    <%= month_calendar events: @schedules, start_time_field: :start_time do |date, schedules| %>
      <div class="text-right text-sm text-gray-500"><%= date.day %></div>
      <% schedules.each do |schedule| %>
        <div class="bg-blue-100 text-blue-900 rounded px-1 py-0.5 mb-1 truncate">
          <span class="font-semibold"><%= schedule.start_time.strftime("%H:%M") %></span>
          <%= schedule.title %>
        </div>
      <% end %>
    <% end %>
  </div>

  <section>
    <h2 class="text-2xl font-bold mb-4">直近の予定</h2>
    <% if @upcoming_schedules.present? %>
      <ul class="space-y-3">
        <% @upcoming_schedules.each do |schedule| %>
          <li class="bg-white rounded-lg shadow p-4">
            <p class="text-lg font-semibold"><%= schedule.title %></p>
            <p class="text-gray-600">
              <%= schedule.start_time.strftime("%Y/%m/%d %H:%M") %>
              <% if schedule.location.present? %>
                ／ <%= schedule.location %>
              <% end %>
            </p>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-gray-600">直近の予定はありません。</p>
    <% end %>
  </section>
</main>
